<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Document</title>
  </head>
  <body>
    <main>
 <% if (error.length > 0) { %>
  <div style="color:#721c24; background:#f8d7da; padding:18px 10px; border-radius:6px; margin-bottom:10px; width: 100%;text-align: center;">
    <%= error[0] %>
  </div>
<% } %>
<% if (success.length > 0) { %>
  <div style="color:green; background:#d4edda;padding:18px 10px; border-radius:6px; text-align:center; margin-bottom:10px;width: 100%;text-align: center;">
    <%= success[0] %>
  </div>
<% } %>
      <h1>Đăng nhập</h1>
      <form method="post">
        <div class="group-input">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            placeholder="a@gmail.com"
            name="email"
          />
        </div>
        <div class="group-input">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            placeholder="Password...."
            name="password"
          />
        </div>
        <button type="submit">Đăng nhập</button>
      </form>
    </main>
  </body>
</html>
